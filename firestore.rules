rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function owner(uid) { return signedIn() && request.auth.uid == uid; }
    function admin() {
      return signedIn() && (
        request.auth.token.email == "s111001@hcvs.hc.edu.tw" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }
    match /users/{uid} { allow read: if signedIn(); allow create: if owner(uid); allow update: if owner(uid) || admin(); allow delete: if admin(); }
    match /progress/{uid} { allow read, write: if owner(uid) || admin(); }
    match /grammarProgress/{uid} { allow read, write: if owner(uid) || admin(); }
    match /communityWords/{id} { allow read: if signedIn(); allow write: if admin(); }
    match /submissions/{id} {
      allow create: if signedIn() && request.resource.data.submittedBy == request.auth.uid;
      allow read: if admin() || (signedIn() && resource.data.submittedBy == request.auth.uid);
      allow update, delete: if admin();
    }
    match /battleRooms/{id} { allow read, create, update: if signedIn(); allow delete: if admin(); }
    match /teams/{id} { allow read, create, update: if signedIn(); allow delete: if admin() || (signedIn() && resource.data.ownerUid == request.auth.uid); }
    match /gameScores/{id} { allow read, create: if signedIn(); allow update, delete: if admin(); }
  }
}
